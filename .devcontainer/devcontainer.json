// For format details, see https://containers.dev/implementors/json_reference/
{
  "name": "PainGouin Dev",
  "dockerComposeFile": [
    "../docker/compose.dev.yaml"
  ],
  "service": "django",
  "customizations": {
    "vscode": {
      "extensions": [
        // python
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        // django
        "batisteo.vscode-django",
        "bradlc.vscode-tailwindcss",
        "monosans.djlint"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[python]": {
          "analysis.autoImportCompletions": true,
          "analysis.typeCheckingMode": "basic",
          "defaultInterpreterPath": "/app/.venv/bin/python",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "always"
          },
          "editor.defaultFormatter": "charliermarsh.ruff",
          "languageServer": "Pylance",
          "linting.enabled": true,
          "linting.mypyEnabled": true,
          "linting.mypyPath": "/app/.venv/bin/mypy"
        },
        "[html][django-html][handlebars][hbs][mustache][jinja][jinja-html][nj][njk][nunjucks][twig]": {
          "editor.defaultFormatter": "monosans.djlint"
        }
      }
    }
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/app",
  // Those commands setup the dev env.
  "postCreateCommand": "cp -u .env.dist .env && uv sync && uv run pre-commit install && uv run manage.py tailwind install && uv run manage.py migrate && uv run manage.py createcachetable",
  "forwardPorts": [
    8000
  ]
}