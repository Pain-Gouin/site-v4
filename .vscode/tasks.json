{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Update complete dependencies",
            "type": "shell",
            "command": "source .venv/bin/activate.fish && pip freeze | xargs pip uninstall -y && pip install -r requirements.minimal.txt && pip freeze > requirements.txt",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated"
            }
        }
    ]
}
